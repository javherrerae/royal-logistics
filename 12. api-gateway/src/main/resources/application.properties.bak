spring.application.name=api-gateway

# Puerto del API Gateway
server.port=8080

# Eureka Configuration
eureka.client.service-url.defaultZone=http://localhost:8761/eureka
eureka.client.register-with-eureka=true
eureka.client.fetch-registry=true

# Logging
logging.level.root=INFO
logging.level.org.springframework.cloud.gateway=DEBUG
logging.level.com.netflix.eureka=INFO

# Gateway Routes Configuration
spring.cloud.gateway.routes[0].id=autenticacion
spring.cloud.gateway.routes[0].uri=lb://autenticacion
spring.cloud.gateway.routes[0].predicates[0]=Path=/api/credenciales/**

spring.cloud.gateway.routes[1].id=producto
spring.cloud.gateway.routes[1].uri=lb://producto
spring.cloud.gateway.routes[1].predicates[0]=Path=/api/productos/**

spring.cloud.gateway.routes[2].id=creacion-usuario
spring.cloud.gateway.routes[2].uri=lb://creacion-usuario
spring.cloud.gateway.routes[2].predicates[0]=Path=/api/empleados/**

spring.cloud.gateway.routes[3].id=anden
spring.cloud.gateway.routes[3].uri=lb://anden
spring.cloud.gateway.routes[3].predicates[0]=Path=/api/andenes/**

spring.cloud.gateway.routes[4].id=camion
spring.cloud.gateway.routes[4].uri=lb://camion
spring.cloud.gateway.routes[4].predicates[0]=Path=/api/camiones/**

spring.cloud.gateway.routes[5].id=recepcion
spring.cloud.gateway.routes[5].uri=lb://recepcion
spring.cloud.gateway.routes[5].predicates[0]=Path=/api/recepciones/**

spring.cloud.gateway.routes[6].id=factura
spring.cloud.gateway.routes[6].uri=lb://factura
spring.cloud.gateway.routes[6].predicates[0]=Path=/api/facturas/**

spring.cloud.gateway.routes[7].id=desconsolidacion
spring.cloud.gateway.routes[7].uri=lb://desconsolidacion
spring.cloud.gateway.routes[7].predicates[0]=Path=/api/desconsolidaciones/**

spring.cloud.gateway.routes[8].id=warehouse
spring.cloud.gateway.routes[8].uri=lb://warehouse
spring.cloud.gateway.routes[8].predicates[0]=Path=/api/warehouse/**

spring.cloud.gateway.routes[9].id=stock
spring.cloud.gateway.routes[9].uri=lb://stock
spring.cloud.gateway.routes[9].predicates[0]=Path=/api/stock/**

spring.cloud.gateway.routes[10].id=movimiento
spring.cloud.gateway.routes[10].uri=lb://movimiento
spring.cloud.gateway.routes[10].predicates[0]=Path=/api/movimientos/**

# Actuator endpoints
management.endpoints.web.exposure.include=health,info,gateway
management.endpoint.health.show-details=always

# ================================================================================================= #
# ===================================== SWAGGER =================================================== #
# ================================================================================================= #


# =========================
# Swagger UI centralizado
# =========================

springdoc.api-docs.enabled=true
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.disable-swagger-default-url=true
springdoc.swagger-ui.urls-primary-name=producto

springdoc.swagger-ui.urls[0].name=recepcion
springdoc.swagger-ui.urls[0].url=/recepcion/v3/api-docs

springdoc.swagger-ui.urls[1].name=camion
springdoc.swagger-ui.urls[1].url=/camion/v3/api-docs

springdoc.swagger-ui.urls[2].name=anden
springdoc.swagger-ui.urls[2].url=/anden/v3/api-docs

springdoc.swagger-ui.urls[3].name=desconsolidacion
springdoc.swagger-ui.urls[3].url=/desconsolidacion/v3/api-docs

springdoc.swagger-ui.urls[4].name=factura
springdoc.swagger-ui.urls[4].url=/factura/v3/api-docs

springdoc.swagger-ui.urls[5].name=producto
springdoc.swagger-ui.urls[5].url=/producto/v3/api-docs

springdoc.swagger-ui.urls[6].name=warehouse
springdoc.swagger-ui.urls[6].url=/warehouse/v3/api-docs

springdoc.swagger-ui.urls[7].name=stock
springdoc.swagger-ui.urls[7].url=/stock/v3/api-docs

springdoc.swagger-ui.urls[8].name=movimiento
springdoc.swagger-ui.urls[8].url=/movimiento/v3/api-docs

springdoc.swagger-ui.urls[9].name=creacion-usuario
springdoc.swagger-ui.urls[9].url=/creacion-usuario/v3/api-docs

springdoc.swagger-ui.urls[10].name=autenticacion
springdoc.swagger-ui.urls[10].url=/autenticacion/v3/api-docs

# =========================
# Rutas Swagger / OpenAPI por Gateway
# =========================


spring.cloud.gateway.routes[11].id=recepcion-docs
spring.cloud.gateway.routes[11].uri=lb://recepcion
spring.cloud.gateway.routes[11].predicates[0]=Path=/recepcion/v3/api-docs
spring.cloud.gateway.routes[11].filters[0]=RewritePath=/recepcion/v3/api-docs, /v3/api-docs

